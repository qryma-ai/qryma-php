{
    "name": "qryma/qryma-php",
    "description": "Qryma Search API PHP SDK",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Qryma Team",
            "email": "support@qryma.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Qryma\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qryma\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
